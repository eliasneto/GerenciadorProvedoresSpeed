DB_PORT=3306

# --- AUTENTICAÇÃO AD / LDAP ---
USE_AD_AUTH=true

# Troque howbe.local pelo IP do servidor AD se o container não resolver o nome
AD_SERVER_URI=ldap://192.168.90.202:389

# Conta de serviço para bind no AD
AD_BIND_DN=servico.ti@howbe.local
AD_BIND_PASSWORD=HowB3@dm1n

# Base de busca
AD_USER_SEARCH_BASE=DC=howbe,DC=local
AD_GROUP_SEARCH_BASE=DC=howbe,DC=local

# Grupo que libera acesso ao sistema
AD_GROUP_SGP_ACCESS=CN=Acesso_SGP,OU=Sistemas,DC=howbe,DC=local

# Pode deixar vazio se o login for por sAMAccountName
AD_DEFAULT_DOMAIN=