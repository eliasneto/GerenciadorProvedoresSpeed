# --- BANCO DE DADOS / DOCKER ---
MYSQL_DATABASE=speed_prod
MYSQL_USER=speed_app
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=

DB_NAME=speed_prod
DB_USER=speed_app
DB_PASSWORD=
DB_HOST=speed_db
DB_PORT=3306

# --- AUTENTICACAO AD / LDAP ---
USE_AD_AUTH=true
AD_SERVER_URI=ldap://192.168.90.51
AD_BIND_DN=servico.ti@howbe.local
AD_BIND_PASSWORD=
AD_USER_SEARCH_BASE=DC=howbe,DC=local
AD_GROUP_SEARCH_BASE=DC=howbe,DC=local
AD_GROUP_SGP_ACCESS=CN=Acesso_SGP,OU=Sistemas,DC=howbe,DC=local
AD_DEFAULT_DOMAIN=HOWBE

# --- ADMIN LOCAL ---
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@speed.com.br
ADMIN_PASSWORD=

# --- EMAIL / SMTP ---
# Exemplo recomendado para Microsoft 365 com caixa compartilhada:
# EMAIL_HOST_USER=sistemas@howbe.com.br
# DEFAULT_FROM_EMAIL=u_cotacao@ultimamilha.net.br
# SERVER_EMAIL=u_cotacao@ultimamilha.net.br
# Observacao: a conta autenticada em EMAIL_HOST_USER precisa ter permissao
# "Enviar como" sobre a caixa compartilhada usada em DEFAULT_FROM_EMAIL.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_TIMEOUT=30
DEFAULT_FROM_EMAIL=admin@speed.com.br
SERVER_EMAIL=admin@speed.com.br

# --- MICROSOFT GRAPH / RESPOSTAS DE E-MAIL DAS COTACOES ---
# Use credenciais app-only do Azure com permissao Mail.Read (ou Mail.ReadWrite)
# sobre a caixa que recebe as respostas das cotacoes.
GRAPH_EMAIL_REPLIES_ENABLED=false
GRAPH_EMAIL_REPLIES_CLIENT_ID=
GRAPH_EMAIL_REPLIES_CLIENT_SECRET=
GRAPH_EMAIL_REPLIES_TENANT_ID=
GRAPH_EMAIL_REPLIES_MAILBOX=u_cotacao@ultimamilha.net.br
GRAPH_EMAIL_REPLIES_INITIAL_LOOKBACK_DAYS=15
GRAPH_EMAIL_REPLIES_TIMEOUT=30
GRAPH_EMAIL_REPLIES_MAX_PAGES_PER_RUN=20

# --- IXC / PAINEL WEB ---
IXC_PANEL_EMAIL=
IXC_PANEL_PASSWORD=

# --- BACKUP / CIFS ---
BACKUP_WINDOWS_USER=
BACKUP_WINDOWS_PASSWORD=
BACKUP_WINDOWS_DOMAIN=HOWBE
BACKUP_WINDOWS_HOST=192.168.90.53
BACKUP_WINDOWS_SHARE=Publica
BACKUP_WINDOWS_SUBDIR=Elias_Prod

# --- GOOGLE / SERPER ---
SERPER_API_KEY=
